# # Environment Variables - Media Website
# # Copy this file to .env and fill in your values

# # MongoDB Atlas
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB_NAME=media_db

# # JWT Authentication
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# # Cloudinary (cho ảnh và thumbnail)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret




# Telegram MTProto (NEW - cho video storage)
# Lấy API ID và API Hash từ https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
# Số điện thoại đăng ký Telegram (cho user authentication)
TELEGRAM_PHONE=+84123456789
# Hoặc sử dụng Bot Token (cho bot authentication)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# ID của private channel để lưu video (phải là số âm, bắt đầu bằng -100)
TELEGRAM_CHANNEL_ID=-1001234567890
# Đường dẫn lưu session (tùy chọn)
TELEGRAM_SESSION_PATH=./telegram_session
# Password 2FA (nếu có)
TELEGRAM_PASSWORD=your-2fa-password
# Đường dẫn file chứa OTP code (cho automated auth)
TELEGRAM_CODE_PATH=./telegram_code.txt



# # Mega.nz (DEPRECATED - giữ lại cho backward compatibility)
# MEGA_EMAIL=your-mega-email@example.com
# MEGA_PASSWORD=your-mega-password



# # Server
# PORT=8080
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://media-y73e.onrender.com/api
